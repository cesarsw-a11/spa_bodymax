datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

model Service {
  id          Int       @id @default(autoincrement())
  name        String
  description String    @db.Text
  /** Inglés (opcional). Si falta, en /en se usa name/description. */
  nameEn        String?
  descriptionEn String?   @db.Text
  imageUrl    String?
  /** Legacy: sincronizado con la primera variante; la reserva usa ServiceVariant. */
  price       Decimal   @db.Decimal(10,2)
  /** Legacy: duración (min) de la primera variante; la reserva usa ServiceVariant. */
  durationMin Int
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  bookings    Booking[]
  variants    ServiceVariant[]
}

model ServiceVariant {
  id          Int      @id @default(autoincrement())
  serviceId   Int
  durationMin Int
  price       Decimal  @db.Decimal(10, 2)
  label       String?  @db.VarChar(191)
  labelEn     String?  @db.VarChar(191)
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  bookings    Booking[]

  @@index([serviceId])
}

model Addon {
  id        Int      @id @default(autoincrement())
  name      String
  price     Decimal  @db.Decimal(10, 2)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Booking {
  id                     Int       @id @default(autoincrement())
  customer               String
  phone                  String
  email                  String?
  serviceId              Int
  serviceVariantId       Int?
  date                   DateTime  // fecha con hora de inicio
  endDate                DateTime  // hora fin calculada
  price                  Decimal   @db.Decimal(10,2)
  status                 BookingStatus @default(PENDING)
  notes                  String?
  addonsJson             String?   @db.LongText // JSON serializado: ids de complementos, ej. "[1,2]"
  stripePaymentIntentId  String?   @db.VarChar(255) // para reembolsos vía Stripe al cancelar
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  service                Service   @relation(fields: [serviceId], references: [id])
  serviceVariant         ServiceVariant? @relation(fields: [serviceVariantId], references: [id])

  @@index([serviceVariantId])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model BlockedSlot {
  id        Int      @id @default(autoincrement())
  start     DateTime
  end       DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
