datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

model Service {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  imageUrl    String?
  price       Decimal   @db.Decimal(10,2)
  durationMin Int       // minutos
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  bookings    Booking[]
}

model Addon {
  id        Int      @id @default(autoincrement())
  name      String
  price     Decimal  @db.Decimal(10, 2)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Booking {
  id                     Int       @id @default(autoincrement())
  customer               String
  phone                  String
  email                  String?
  serviceId              Int
  date                   DateTime  // fecha con hora de inicio
  endDate                DateTime  // hora fin calculada
  price                  Decimal   @db.Decimal(10,2)
  status                 BookingStatus @default(PENDING)
  notes                  String?
  addonsJson             String?   @db.LongText // JSON serializado: ids de complementos, ej. "[1,2]"
  stripePaymentIntentId  String?   @db.VarChar(255) // para reembolsos vía Stripe al cancelar
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  service                Service   @relation(fields: [serviceId], references: [id])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model BlockedSlot {
  id        Int      @id @default(autoincrement())
  start     DateTime
  end       DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}